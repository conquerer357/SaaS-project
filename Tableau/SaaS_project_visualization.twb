          <datasource-dependencies datasource='federated.1te4j2v11rnavq1b2rmuc1utiu0r'>
            <column caption='Plan change Category' datatype='string' name='[Calculation_613615482948911104]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [precedingupgrade] = True AND [precedingdowngrade] = False THEN &quot;Upgraded Before Churn&quot;&#13;&#10;ELSEIF [precedingupgrade] = False AND [precedingdowngrade] = True THEN &quot;Downgraded Before Churn&quot;&#13;&#10;ELSEIF [precedingupgrade] = True AND [precedingdowngrade] = True THEN &quot;Multiple Plan Changes&quot;&#13;&#10;ELSE &quot;No Plan Change&quot;&#13;&#10;END' />
            </column>
            <column caption='Churnevents' datatype='integer' name='[churnevents]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_613615482948911104]' derivation='None' name='[none:Calculation_613615482948911104:nk]' pivot='key' type='nominal' />
            <column caption='Precedingdowngrade' datatype='boolean' name='[precedingdowngrade]' role='dimension' type='nominal' />
            <column caption='Precedingupgrade' datatype='boolean' name='[precedingupgrade]' role='dimension' type='nominal' />
            <column-instance column='[churnevents]' derivation='Sum' name='[sum:churnevents:qk]' pivot='key' type='quantitative' />
