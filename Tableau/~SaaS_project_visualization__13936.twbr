    <worksheet name='Feature Usage Table'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Tableau Bold' fontsize='20'>Feature Usage Comparison: Churned vs Retained</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Tableau Bold' fontsize='14'>Gap = Churned Avg Usage - Retained Average Usage. Red = churned used less.</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='churn_status_by_feature' name='federated.03ssqw015sogkb14penbe0qzzuf6' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='View Type' datatype='string' datatype-customized='true' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Top&quot;'>
              <calculation class='tableau' formula='&quot;Top&quot;' />
            </column>
            <column caption='Number of Features' datatype='integer' name='[Parameter 2]' param-domain-type='range' role='measure' type='quantitative' value='20'>
              <calculation class='tableau' formula='20' />
              <range granularity='5' max='40' min='5' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.03ssqw015sogkb14penbe0qzzuf6'>
            <column caption='Churned Accounts' datatype='integer' name='[Calculation_1407374917356916736]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [churnstatus] = &quot;churned&quot; THEN [accounts] ELSE 0 END)' />
            </column>
            <column caption='Retained Accounts' datatype='integer' name='[Calculation_1407374917357010945]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [churnstatus] = &quot;notchurned&quot; THEN [accounts] ELSE 0 END)' />
            </column>
            <column caption='Churned Avg Usage' datatype='real' name='[Calculation_1407374917357367298]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [churnstatus] = &quot;churned&quot; THEN [avgusage] * [accounts] ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF [churnstatus] = &quot;churned&quot; THEN [accounts] ELSE 0 END)' />
            </column>
            <column caption='Retained Avg Usage' datatype='real' name='[Calculation_1407374917357445123]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [churnstatus] = &quot;notchurned&quot; THEN [avgusage] * [accounts] ELSE 0 END)&#13;&#10;/&#13;&#10;SUM(IF [churnstatus] = &quot;notchurned&quot; THEN [accounts] ELSE 0 END)' />
            </column>
            <column caption='Usage difference' datatype='real' name='[Calculation_1407374917357568004]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1407374917357367298] - [Calculation_1407374917357445123]' />
            </column>
            <column caption='Feature Rank ' datatype='integer' name='[Calculation_2013109067529297920]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK([Calculation_1407374917356916736], &apos;desc&apos;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Top Bottom Selector' datatype='boolean' name='[Calculation_2013109067530911745]' role='measure' type='nominal'>
